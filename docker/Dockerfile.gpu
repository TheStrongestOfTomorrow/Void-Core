# Void AI — GPU-enabled Docker Image
# Requires NVIDIA Container Toolkit: https://docs.nvidia.com/datacenter/cloud-native/container-toolkit/install-guide.html

FROM node:20-alpine AS web-builder
WORKDIR /app/void-ai
COPY void-ai/package*.json ./
RUN npm ci --only=production
COPY void-ai/ ./
RUN npm run build

FROM python:3.11-slim

# Install system dependencies for GPU support
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install NVIDIA Container Toolkit (for Ollama GPU acceleration)
# This requires the host to have NVIDIA drivers + nvidia-container-toolkit installed

WORKDIR /void-ai

# Install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Install Ollama with GPU support
RUN curl -fsSL https://ollama.com/install.sh | sh

# Copy web build
COPY --from=web-builder /app/void-ai/.next/standalone ./
COPY --from=web-builder /app/void-ai/.next/static ./.next/static
COPY --from=web-builder /app/void-ai/public ./public

# Copy core
COPY src/ ./src/
COPY bin/ ./bin/
COPY models/ ./models/
COPY void.config ./

# Make binaries executable
RUN chmod +x bin/void-ai bin/void-code

# Pre-pull models
RUN ollama create void-1 -f models/void-1/Modelfile || true
RUN ollama create void-2 -f models/void-2/Modelfile || true

ENV PORT=3000
ENV VOID_MODE=production
ENV VOID_RAM_LIMIT=4294967296
ENV NVIDIA_VISIBLE_DEVICES=all
ENV NVIDIA_DRIVER_CAPABILITIES=compute,utility

EXPOSE 3000 11434

# Start Ollama in background, then start Void AI server
CMD ollama serve & sleep 3 && python3 src/api/server.py
