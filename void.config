{
  "version": "1.0.0",
  "name": "Void AI",
  "ram_limit_mb": 2048,
  "models": {
    "void-1": {
      "name": "Void-1: Code Model",
      "size_mb": 100,
      "base": "Qwen2.5-Coder-0.5B",
      "quantization": "Q4_K_M"
    },
    "void-2": {
      "name": "Void-2: Linguistic Model",
      "size_mb": 100,
      "base": "Phi-3-mini-4k",
      "quantization": "Q4_K_M"
    },
    "void-moa": {
      "name": "Void-MOA: Mixture of Agents",
      "type": "router",
      "routes_to": ["void-1", "void-2"]
    }
  },
  "features": {
    "chat": true,
    "deepthink": true,
    "agent": true,
    "voidcode": true,
    "web_search": true,
    "file_io": true,
    "shell_exec": true
  },
  "platforms": ["linux-amd64", "linux-arm64", "darwin-amd64", "darwin-arm64", "android-termux"]
}
